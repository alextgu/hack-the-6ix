# ─── Telegram + Mini App ────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_botfather_token_here
# Public HTTPS URL for the Mini App (Telegram requires HTTPS).
# Get one from `cloudflared tunnel --url http://localhost:8000` or `ngrok http 8000`.
PUBLIC_WEBAPP_URL=

# ─── Stay22 (booking + live market pressure) ────────────────────────────────
STAY22_API_KEY=your_api_key_here
STAY22_AID=trippet

# ─── Read seam — Gemini, permanently (PIPELINE.md) ──────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash-exp

# ─── Agent seam — Freesolo (phoebe.py, once trained + deployed) ─────────────
# Sign-up discount: use code `hackthe6ix`.
# FREESOLO_AGENT_BASE_URL comes from `flash deployments --json` after you
# train + deploy the Phoebe agent run. Format: https://<your-deployment>/v1
# Leaving it blank makes phoebe.py fall back to Gemini.
FREESOLO_API_KEY=your_freesolo_api_key_here
FREESOLO_AGENT_BASE_URL=
FREESOLO_AGENT_MODEL=phoebe-agent-v1


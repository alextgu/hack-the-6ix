# ─── Required-ish (any one missing degrades to a stub, app still boots) ─────
TELEGRAM_BOT_TOKEN=your_botfather_token_here
STAY22_API_KEY=your_api_key_here
STAY22_AFFILIATE_ID=kamagachi
GEMINI_API_KEY=your_gemini_api_key_here
# MongoDB Atlas — card sessions, swipes + interaction analytics (db.py).
# Atlas → Network Access must allow your IP (or 0.0.0.0/0 for the hackathon).
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=Cluster0
MONGODB_DB=trippet
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# ElevenLabs voice ids — swap for your preferred "weak/sad" and "bright" voices
ELEVENLABS_VOICE_DYING=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_VOICE_ALIVE=EXAVITQu4vr4xnSDxMaL

# Phoebe SDK — diagnose-target-convince agent for events/activities + holdout DMs
PHOEBE_API_KEY=your_phoebe_api_key_here
PHOEBE_API_URL=https://api.phoebe.ai

# Freesolo — post-trained Phoebe AGENT model. See PIPELINE.md.
# Sign-up discount: use code `hackthe6ix`.
#
# IMPORTANT: Freesolo lives on the AGENT seam (phoebe.py), NOT the Read seam.
# Read (brain.py) stays on Gemini, permanently. Keep FREESOLO_BASE_URL blank
# — that's the legacy Read-seam key from an earlier miswiring.
#
# FREESOLO_AGENT_BASE_URL comes from `flash deployments --json` after you
# train + deploy the Phoebe agent run. Format: https://<your-deployment>/v1
FREESOLO_API_KEY=your_freesolo_api_key_here
FREESOLO_BASE_URL=
FREESOLO_AGENT_BASE_URL=
FREESOLO_AGENT_MODEL=phoebe-agent-v1
FREESOLO_MODEL=freesolo-read-v1

# Public HTTPS URL for the Mini App (Telegram requires HTTPS).
# Get one from `cloudflared tunnel --url http://localhost:8000` or `ngrok http 8000`.
PUBLIC_WEBAPP_URL=https://your-tunnel-url.example

# Legacy — kept only for the older kamagachi/ scaffold. Ignore for the trippet build.
PUBLIC_BASE_URL=https://your-tunnel-url.example
TELEGRAM_WEBHOOK_SECRET=kamagachi-secret

# Model + demo toggles
GEMINI_MODEL=gemini-2.0-flash-exp
DEMO_MODE=1

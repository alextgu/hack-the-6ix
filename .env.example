# Copy to .env and fill in. .env is gitignored.
# [REQUIRED] = the bot won't function without it. [OPTIONAL] = safe to leave blank.

# ─── Telegram + Mini App ────────────────────────────────────────────────────
# [REQUIRED] BotFather token. Without it, run.py starts in API-only mode
# (Mini App serves, no Telegram polling) and bot.py exits with a clear message.
TELEGRAM_BOT_TOKEN=your_botfather_token_here
# [OPTIONAL] Public HTTPS URL for the Mini App (Telegram requires HTTPS).
# Get one from `cloudflared tunnel --url http://localhost:8000` or `ngrok http 8000`,
# or the stable https://…run.app URL once deployed on Cloud Run.
PUBLIC_WEBAPP_URL=
# [OPTIONAL] Port for the FastAPI face server (run.py). Default 8000.
# Cloud Run injects this automatically.
PORT=8000

# ─── MongoDB Atlas — card sessions, swipes + interaction analytics (db.py) ──
# [OPTIONAL] Blank → memory-only (no persistence); the app runs fine without it.
# Atlas → Network Access must allow the caller's IP (0.0.0.0/0 for the hackathon).
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=Cluster0
# [OPTIONAL] Database name. Default: trippet.
MONGODB_DB=trippet

# ─── Stay22 (booking + live market pressure) ────────────────────────────────
# [OPTIONAL] Blank → keyless demo tier (5 req/min, throttled to >12s in
# stay22.py). Set → authenticated tier (150 req/min) and the throttle drops to
# 0.5s. Sent as the X-API-KEY header — NOT `Authorization: Bearer`, which the
# gateway silently ignores.
STAY22_API_KEY=your_api_key_here
# [OPTIONAL] Affiliate ID baked into the Allez booking URLs Stay22 returns.
STAY22_AID=trippet
# [OPTIONAL] Display currency (ISO 4217). One of USD/CAD/EUR/GBP/JPY/AUD;
# anything else logs a warning and falls back to USD. Default: USD.
STAY22_CURRENCY=USD
# [OPTIONAL] Deck spread. "top" = one best-rated stay per H3 cell, so cards
# span neighbourhoods instead of one block. Set to "off" for a flat list if
# clustering misbehaves live. Default: top.
STAY22_CLUSTER=top
# [OPTIONAL] H3 resolution for cluster=top (r7 ~1.2km cells). Default: 7.
STAY22_CLUSTER_PRECISION=7
# [OPTIONAL] Minimum review count for a cell's elected representative. Without
# a floor, 4-review rentals win every hexagon and the cross-supplier price
# comparison disappears. Default: 100.
STAY22_MIN_REVIEWS=100

# ─── Flights — Amadeus Self-Service TEST API (green.py scores them) ─────────
# [OPTIONAL] Blank → flights.py serves data/flight_offers.json, then the
# seeded mock generator. The demo works fully without these; CO2e is always
# computed locally (DEFRA factors), so no API can break the green numbers.
# Free test creds: https://developers.amadeus.com → My Self-Service Workspace.
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=

# ─── Read seam — Gemini, permanently (PIPELINE.md) ──────────────────────────
# [REQUIRED for live chat→constraints] Blank → brain.extract raises a clear
# error naming this var; the demo runner falls back to fixtures.
GEMINI_API_KEY=your_gemini_api_key_here
# [OPTIONAL] Read-seam model. Use gemini-flash-latest (gemini-2.0-flash-exp is
# retired and 404s).
GEMINI_MODEL=gemini-flash-latest

# ─── Agent seam — Phoebe / Tabi voice (phoebe.py) ─────────────────────
# Provider selection cascade:
#   1. FREESOLO_AGENT_BASE_URL set → Freesolo (post-trained agent)
#   2. Else PHOEBE_PROVIDER: "gemini" (default) or "anthropic"
# [OPTIONAL] Model overrides via PHOEBE_MODEL (else per-provider fast default).
PHOEBE_PROVIDER=gemini
PHOEBE_MODEL=


# ─── Freesolo agent adapter (sign-up discount code `hackthe6ix`) ────────────
# [OPTIONAL] FREESOLO_AGENT_BASE_URL comes from `flash deployments --json`
# after you train + deploy. Blank → the PHOEBE_PROVIDER path above is used.
# NOTE: put the real key in .env only (gitignored) — never commit it here.
FREESOLO_API_KEY=your_freesolo_api_key_here
FREESOLO_AGENT_BASE_URL=
FREESOLO_AGENT_MODEL=phoebe-agent-v1

# ─── Trip destination ───────────────────────────────────────────────────────
# [OPTIONAL] The country this bot plans trips to. Injected into the messenger
# prompt so the pet can never suggest or default to a city outside it — left
# unset in the prompt once, it defaulted a Japan trip to Chicago. Everything
# downstream (stay22.CITY_COORDS, green.CITY_AIRPORT, the basecamp) is
# Japan-only too, so an off-country city breaks hotels and flights.
TRIP_COUNTRY=Japan
TRIP_CITY_EXAMPLES=Tokyo, Kyoto, Osaka, Sapporo, Fukuoka, Nara, Hakone

# ─── Voice (ElevenLabs) ─────────────────────────────────────────────────────
# [OPTIONAL] Blank ELEVENLABS_API_KEY → voice disabled (text/image only, fails
# safe). The key is an `sk_...` value — the variable name MUST be
# ELEVENLABS_API_KEY (a bare `ELEVENLABS=` is NOT read by the code).
# Tabi is ONE character (a young Japanese girl), so both ids are the same
# voice — mood changes the DELIVERY via voice_settings in elevenlabs.py
# (dying = lower stability, higher style: wavering and desperate), not the
# casting. Two different voice ids made her sound like two different people.
# ELEVENLABS_VOICE_ID is only a legacy single-voice fallback.
ELEVENLABS_API_KEY=your_sk_key_here
ELEVENLABS_VOICE_ALIVE=lhTvHflPVOqgSWyuWQry
ELEVENLABS_VOICE_DYING=lhTvHflPVOqgSWyuWQry
ELEVENLABS_VOICE_ID=
# [OPTIONAL] Pet physical health at/below which replies go out as voice notes
# instead of text. Above it the pet types, so the voice keeps its weight.
# Default 40 — the point the strained DYING voice takes over, so the switch to
# speech and the switch to the sicker voice happen together.
VOICE_HEALTH_THRESHOLD=40

# ─── Solana — "Japan Trip Coin" souvenir, minted on /commit (devnet only) ───
# [OPTIONAL] Blank SOLANA_TREASURY_SECRET → minting skipped silently; the
# booking is never affected. Devnet only — mainnet is refused in code.
# The minting wallet — a devnet keypair as a JSON secret-key array [n,n,...].
# Generate: (cd solana && node -e "import('@solana/web3.js').then(w=>console.log(JSON.stringify(Array.from(w.Keypair.generate().secretKey))))")
# Then FUND it once at https://faucet.solana.com (paste the pubkey, request 1
# SOL — RPC/CLI faucets are IP-rate-limited; the browser faucet is separate).
SOLANA_TREASURY_SECRET=[ ... 64 ints ... ]
# Coin art shown in-chat + referenced in the token metadata.
TRIP_COIN_IMAGE_URL=https://raw.githubusercontent.com/alextgu/hack-the-6ix/main/assets/trip_coin.jpeg


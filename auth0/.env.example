# Auth0 application settings (SPA / Single Page Application).
# Create an application at https://manage.auth0.com → Applications → Create.
# Copy to auth0/.env and fill in; these are NOT secrets (client-side values),
# but keep .env out of git anyway.
AUTH0_DOMAIN=YOUR_TENANT.us.auth0.com
AUTH0_CLIENT_ID=YOUR_AUTH0_CLIENT_ID
